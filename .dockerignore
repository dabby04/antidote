# Ignore everything by default, then opt in only runtime assets.
**

# Required build files
!Dockerfile
!requirements.txt
!utils.py

# Backend entrypoint
!Demo/
Demo/**
!Demo/server.py

# Evaluation data used by /examples
!pi-detection-data/
pi-detection-data/**
!pi-detection-data/t1_llmail.parquet
!pi-detection-data/t2_hackaprompt.parquet
!pi-detection-data/t3_bipia.parquet

